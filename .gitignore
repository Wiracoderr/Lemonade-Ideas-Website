# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts\n# Unused reference files\n_Unused_Reference_Files/\n
# Unused reference files
_Unused_Reference_Files/

# Diagnostic Files (Ignored to prevent Tailwind v4 CSS scanner crashes)
verify_*.html
temp_html.txt
lh-report.json
output_insights.txt
pagespeed_extracted.txt
parse_lcp*.js
parse_lcp*.py
*.report.html
build_err*.txt

